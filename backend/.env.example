# Environment
APP_ENV=dev

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/cosmicforge_rtc

# Server Configuration
HOST=127.0.0.1 #on production change to your server ip or 0.0.0.0
PORT=8080


# Google OAuth2 Configuration
# These values must match what you set in the Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# This must match what you saved in the Google Cloud Console
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production

# Email Configuration (SMTP)
# Required for sending verification emails
# If not configured, verification tokens will be logged to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Optional email settings
# IMPORTANT: For Gmail, SMTP_FROM_EMAIL must match SMTP_USERNAME
# Gmail rejects emails where the "from" address differs from the authenticated account
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=CosmicForge

# Email Verification
# Require users to verify their email before login (true/false)
EMAIL_VERIFICATION_REQUIRED=true

# Frontend URLs (comma-separated for CORS)
# Add all your frontend URLs: local, staging, production
FRONTEND_URLS=http://localhost:3000,http://localhost:3001

# Primary app URL (used for email links, join URLs, etc.)
APP_URL=http://localhost:3000

# LiveKit Configuration (Required for RTC)
# Get these from your LiveKit Cloud dashboard or self-hosted LiveKit server
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Logging
RUST_LOG=debug

# For production use:
# RUST_LOG=backend=info,tower_http=warn
